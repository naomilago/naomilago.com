---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';

const lang = Astro.currentLocale ?? 'en';

const skills = [
  { name: 'Python', pct: 99 },
  { name: 'NLP / LLMs', pct: 86 },
  { name: 'RAG', pct: 80 },
  { name: 'PySpark', pct: 94 },
  { name: 'LangGraph', pct: 83 },
  { name: 'PyTorch', pct: 78 },
  { name: 'SQL', pct: 91 },
  { name: 'MLOps', pct: 75 },
];
---

<BaseLayout title="About — Naomi Lago" description="AI Engineer with 4+ years building NLP, LLM agents, and large-scale ML systems.">
  <Navbar lang={lang} />
  <div class="page-body">

    <!-- Hero bio -->
    <section class="bg-[#f4f2fb] dark:bg-[#0f0d20] border-b border-[#e8e3f5] dark:border-[#1e1a38] py-14">
      <div class="container">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
          <!-- Text -->
          <div>
            <span class="inline-block mb-4 bg-[#ede9f8] dark:bg-[#1e1a40] text-[#5c3fa3] dark:text-[#b89aec] text-[9px] font-medium tracking-[0.08em] px-3 py-1 rounded-full">
              AI Engineer
            </span>
            <h1 class="text-[28px] font-medium tracking-[-0.02em] text-[#150a35] dark:text-[#e2dcff] mb-4 leading-snug">
              Hey, I'm Naomi —<br>I build scalable data and AI systems.
            </h1>
            <p class="text-[14px] text-[#555] dark:text-[#7a7aaa] leading-[1.75] max-w-[520px]">
              &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;I’m Naomi Lago, a Data & AI Engineer focused on helping companies build scalable data, AI, and automation systems. My work sits across data engineering, machine learning, APIs, and software integration, with an emphasis on turning technical complexity into practical systems that support real operations and products.
            </p>
            <p class="text-[14px] text-[#555] dark:text-[#7a7aaa] leading-[1.75] max-w-[520px]">
              &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;I work best on problems that require both technical depth and clear execution — from data foundations and intelligent workflows to internal tools, integrations, and automation. My approach is straightforward: understand the real problem, design a clean path forward, and build systems that are reliable, scalable, and useful in practice.
            </p>
          </div>
          <!-- Avatar placeholder -->
          <div class="flex justify-center md:justify-end">
            <div class="w-[160px] h-[160px] bg-[#ede9f8] dark:bg-[#1e1a40] rounded-[12px] flex items-center justify-center">
              <img src='https://naomilago.com/profile.jpeg' style='border-radius: 12px;' />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Experience timeline -->
    <section class="py-14 border-b border-[#e8e3f5] dark:border-[#1e1a38]">
      <div class="container">
        <span class="text-[10px] font-medium tracking-[0.08em] text-[#999] dark:text-[#5a5888] block mb-8">Experience</span>
        <div class="space-y-6 max-w-[640px]">
          <!-- Item -->
          <div class="grid grid-cols-[80px_1fr] gap-6 items-start">
            <span class="text-[12px] font-medium text-[#7c5cbf] dark:text-[#b89aec] text-right pt-0.5">2022 – 2026</span>
            <div>
              <p class="text-[14px] font-medium text-[#150a35] dark:text-[#e2dcff] mb-0.5">Data Scientist · Nestlé</p>
              <p class="text-[12px] text-[#777] dark:text-[#6868a0]">Worked as a Data Scientist across multiple teams at Nestlé, developing NLP solutions such as sentiment analysis and message tagging. Contributed to B2B prioritization and order recommender systems using business segmentation and RFV analysis, improving operational efficiency. Strengthened expertise in probabilistic models, Deep Learning, MLflow, and Data Science pipelines through high-impact, production-level projects.</p>
            </div>
          </div>
          <div class="grid grid-cols-[80px_1fr] gap-6 items-start">
            <span class="text-[12px] font-medium text-[#7c5cbf] dark:text-[#b89aec] text-right pt-0.5">2022 – 2023</span>
            <div>
              <p class="text-[14px] font-medium text-[#150a35] dark:text-[#e2dcff] mb-0.5">Data Science Analyst · Nestlé</p>
              <p class="text-[12px] text-[#777] dark:text-[#6868a0]">Started as part of the first Data Scientisttraining cohort, completing the program in February 2023. Gained handson experience in data collection (including web scraping), EDA, data cleaning, feature engineering, and model evaluation. During this period, I identified a strong interest in Artificial Intelligence, particularly Natural Language Processing (NLP) applications.</p>
            </div>
          </div>
          <div class="grid grid-cols-[80px_1fr] gap-6 items-start">
            <span class="text-[12px] font-medium text-[#7c5cbf] dark:text-[#b89aec] text-right pt-0.5">2022 – 2022</span>
            <div>
              <p class="text-[14px] font-medium text-[#150a35] dark:text-[#e2dcff] mb-0.5">UX/UI Designer · Cliqx</p>
              <p class="text-[12px] text-[#777] dark:text-[#6868a0]"></p>
            </div>
          </div>
          <div class="grid grid-cols-[80px_1fr] gap-6 items-start">
            <span class="text-[12px] font-medium text-[#7c5cbf] dark:text-[#b89aec] text-right pt-0.5">2021 – 2022</span>
            <div>
              <p class="text-[14px] font-medium text-[#150a35] dark:text-[#e2dcff] mb-0.5">Help Desk Analyst · Cliqx</p>
              <p class="text-[12px] text-[#777] dark:text-[#6868a0]"></p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Skills grid -->
    <section class="py-14">
      <div class="container">
        <span class="text-[10px] font-medium tracking-[0.08em] text-[#999] dark:text-[#5a5888] block mb-8">Skills</span>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {skills.map(skill => (
            <div class="bg-white dark:bg-[#12102a] border border-[#e8e3f5] dark:border-[#22203a] rounded-xl p-4">
              <div class="flex justify-between items-center mb-3">
                <span class="text-[13px] font-medium text-[#150a35] dark:text-[#e2dcff]">{skill.name}</span>
                <span class="text-[11px] text-[#999] dark:text-[#5a5888]">{skill.pct}%</span>
              </div>
              <div class="h-[3px] bg-[#e8e3f5] dark:bg-[#22203a] rounded-full overflow-hidden">
                <div class="h-full bg-[#7c5cbf] rounded-full" style={`width: ${skill.pct}%`}></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

  </div>
</BaseLayout>
