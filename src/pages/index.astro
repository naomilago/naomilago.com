---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { t } from '../i18n/utils';

const lang = Astro.currentLocale ?? 'en';

const projects = [
  {
    title: lang === 'pt' ? 'Yara: Assistente Trans-Afirmativa'  : 'Yara: Trans-Affirmative Assistant',
    desc:  lang === 'pt' ? 'Yara é uma inteligência artificial trans-afirmativa disponível 24h pelo WhatsApp. Saúde, direitos e acolhimento para a comunidade trans e não-binária brasileira, sem julgamentos.' : 'Yara is a trans-affirming artificial intelligence available 24/7 on WhatsApp. Health, rights, and support for the Brazilian trans and non-binary community, without judgment.',
    tag: 'LangGraph', icon: 'yara',
  },
  {
    title: lang === 'pt' ? 'Kedward: Sistema RAG para o Cosmos de Carl Sagan' : 'Kedward: RAG System for Carl Sagan\'s Cosmos',
    desc:  lang === 'pt' ? 'Kedward é um sistema impulsionado por IA projetado para fornecer respostas perspicazes a perguntas sobre o "Cosmos" de Carl Sagan. Ele combina o poder dos Modelos de Linguagem de Grande Escala (LLMs) com uma base de conhecimento personalizada para entregar respostas precisas e contextualmente conscientes.' : 'Kedward is an AI-powered system designed to provide insightful answers to questions about Carl Sagan\'s "Cosmos". It combines the power of Large Language Models (LLMs) with a custom knowledge base to deliver accurate and context-aware responses.',
    tag: 'RAG', icon: 'kedward',
  },
  {
    title: lang === 'pt' ? 'Diver' : 'Diver',
    desc:  lang === 'pt' ? 'Diver é um chatbot impulsionado por IA que te ajuda a navegar pelo meu blog de tecnologia. Ele pode responder perguntas sobre meus posts, minhas habilidades tecnológicas e meus projetos. Também pode te ajudar explicando conceitos complexos de forma simples e amigável.' : 'Diver is an AI-powered chatbot that helps you navigate my tech blog. It can answer questions about my blog posts, my technology skills, and my projects. It can also help you by explaining complex concepts in simple terms and also in a friendly manner.',
    tag: 'LLM', icon: 'diver',
  },
];
---

<BaseLayout
  title="Naomi Lago — Data & AI Engineer"
  description="Data & AI Engineer portfolio focused on building scalable machine learning systems, recommendation engines, and data pipelines using Python, PySpark, and modern AI tools.">

  <Navbar lang={lang} />

  <!-- page-body: flex column that fills remaining viewport after sticky navbar -->
  <div class="page-body">

    <!-- Hero: grows to fill space between navbar and projects -->
    <section class="hero">
      <div class="hero-left">
        <div class="hero-left-content">

          <span class="hero-pill">{t(lang, 'hero_pill')}</span>

          <h1 class="hero-h1">
            Building intelligent<br>systems that scale.
          </h1>

          <p class="hero-sub">{t(lang, 'hero_subtitle')}</p>

          <div class="hero-tags">
            <span class="tag">NLP</span>
            <span class="tag">LLMs</span>
            <span class="tag">Agents</span>
            <span class="tag">PyTorch</span>
            <span class="tag">PySpark</span>
            <span class="tag">MLOps</span>
          </div>

          <div style="display:flex; gap:12px; flex-wrap:wrap;">
            <a href={lang === 'pt' ? 'https://form.typeform.com/to/JsbA8CPu' : 'https://form.typeform.com/to/JsbA8CPu'} target="_blank" class="btn-primary">
              {t(lang, 'hero_btn_cta')}
            </a>
            <a href={lang === 'pt' ? '/pt/blog' : '/blog'} class="btn-ghost">
              {t(lang, 'hero_btn_blog')}
            </a>
          </div>

        </div>
      </div>

      <div class="hero-right">
        <pre class="hero-code"><span class="cmt"># multi-agent pipeline</span>
<span class="kw">from</span> langgraph.graph <span class="kw">import</span> <span class="fn">StateGraph</span>

graph = <span class="fn">StateGraph</span>(AgentState)
graph.<span class="fn">add_node</span>(<span class="str">"planner"</span>, plan)
graph.<span class="fn">add_node</span>(<span class="str">"executor"</span>, run)
graph.<span class="fn">add_edge</span>(<span class="str">"planner"</span>, <span class="str">"executor"</span>)
<span class="cmt"># language is the interface ✦</span></pre>
      </div>
    </section>

    <!-- Featured Projects: sticks to bottom of page-body -->
    <section class="projects">
      <div class="projects-inner">
        <div class="projects-header">
          <span class="projects-label">{t(lang, 'featured_projects')}</span>
          <a href={lang === 'pt' ? '/pt/portfolio' : '/portfolio'} class="projects-see-all">
            {t(lang, 'see_all')}
          </a>
        </div>
        <div class="projects-grid">
          {projects.map(p => (
            <ProjectCard title={p.title} description={p.desc} tag={p.tag} icon={p.icon} />
          ))}
        </div>
      </div>
    </section>

  </div>

</BaseLayout>