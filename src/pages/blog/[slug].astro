---
import PostLayout from '../../layouts/PostLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const enPosts = posts.filter(p => p.data.lang === 'en');
  return enPosts.map(post => ({
    params: { slug: post.slug },
    props: { entry: post, allPosts: posts },
  }));
}

const { entry, allPosts } = Astro.props;
const lang = Astro.currentLocale ?? 'en';

const translatedPost = entry.data.reference 
  ? allPosts.find(p => p.data.reference === entry.data.reference && p.data.lang === 'pt')
  : null;

const altHref = translatedPost ? `/pt/blog/${translatedPost.slug}` : '/pt/blog';
---

<PostLayout entry={entry} altHref={altHref}>
</PostLayout>
