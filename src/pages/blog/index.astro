---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import BlogPostRow from '../../components/BlogPostRow.astro';
import { getCollection } from 'astro:content';

import { t } from '../../i18n/utils';

const lang = Astro.currentLocale ?? 'en';
const allPosts = await getCollection('blog');
const enPosts = allPosts.filter(p => p.data.lang === 'en');
const enReferences = new Set(enPosts.map(p => p.data.reference).filter(Boolean));

const posts = allPosts.filter(p => {
  if (p.data.lang === 'en') return true;
  if (p.data.lang === 'pt') {
    if (p.data.reference && enReferences.has(p.data.reference)) return false;
    return true;
  }
  return false;
}).sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

const allTags = ['All', ...Array.from(new Set(posts.flatMap(p => p.data.tags)))];
---

<BaseLayout title="Blog — Naomi Lago" description="Thoughts on NLP, agents, and building ML systems that actually work.">
  <Navbar lang={lang} />
  <div class="page-body">

    <!-- Header -->
    <section class="bg-[#F4F2Fb] dark:bg-[#0f0d20] border-b border-[#e8e3f5] dark:border-[#1e1a38] py-12">
      <div class="container">
        <h1 class="text-[28px] font-medium tracking-[-0.02em] text-[#150a35] dark:text-[#e2dcff] mb-2">Blog</h1>
        <p class="text-[14px] text-[#555] dark:text-[#7a7aaa]">Thoughts on NLP, agents, and building ML systems that actually work.</p>
      </div>
    </section>

    <!-- Filters + Posts -->
    <section class="py-10">
      <div class="container">

        <!-- Search -->
        <div class="mb-6 max-w-md">
          <input
            type="text"
            id="search-input"
            placeholder={t(lang, 'search_placeholder')}
            class="w-full px-4 py-2 text-[14px] bg-[#FCFBFF] dark:bg-[#0f0d20] border border-[#e8e3f5] dark:border-[#1e1a38] rounded-lg text-[#150a35] dark:text-[#e2dcff] focus:outline-none focus:border-[#7c5cbf] transition-colors"
          />
        </div>

        <!-- Filter pills -->
        <div class="flex gap-2 mb-8 flex-wrap" id="filter-bar">
          {allTags.map(tag => (
            <button
              data-tag={tag}
              class={`filter-btn text-[11px] font-medium tracking-[0.04em] px-3 py-1.5 rounded-full transition-colors duration-150 ${tag === 'All' ? 'bg-[#ede9f8] dark:bg-[#1e1a40] text-[#5c3fa3] dark:text-[#b89aec]' : 'bg-[#FCFBFF] dark:bg-[#0f0d20] text-[#777] dark:text-[#6868a0] border border-[#e8e3f5] dark:border-[#1e1a38]'}`}>
              {tag}
            </button>
          ))}
        </div>

        <!-- Post list -->
        <div id="post-list">
          {posts.map(post => {
            const isOnlyPortuguese = post.data.lang === 'pt';
            return (
              <div class="post-item" data-tags={post.data.tags.join(',')} data-title={post.data.title.toLowerCase()}>
                <BlogPostRow
                  title={post.data.title}
                  excerpt={post.data.excerpt}
                  date={post.data.date}
                  readTime={post.data.readTime}
                  tags={post.data.tags}
                  slug={post.slug}
                  lang={lang}
                />
                {isOnlyPortuguese && (
                  <p class="text-[11px] text-[#7c5cbf] dark:text-[#b89aec] mb-1 -mt-2 px-0">{t(lang, 'post_only_portuguese')}</p>
                )}
              </div>
            );
          })}
        </div>

        {posts.length === 0 && (
          <p class="text-[14px] text-[#999] dark:text-[#5a5888] py-12 text-center">No posts yet. Check back soon.</p>
        )}
      </div>
    </section>

  </div>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const items = document.querySelectorAll('.post-item');
  const searchInput = document.getElementById('search-input') as HTMLInputElement;

  const activeClass = ['bg-[#ede9f8]', 'dark:bg-[#1e1a40]', 'text-[#5c3fa3]', 'dark:text-[#b89aec]'];
  const inactiveClass = ['bg-[#f4f2fb]', 'dark:bg-[#0f0d20]', 'text-[#777]', 'dark:text-[#6868a0]', 'border', 'border-[#e8e3f5]', 'dark:border-[#1e1a38]'];

  let activeTag = 'All';
  let searchQuery = '';

  function filterPosts() {
    items.forEach(item => {
      const tags = (item.getAttribute('data-tags') ?? '').split(',');
      const title = item.getAttribute('data-title') ?? '';
      
      const matchesTag = activeTag === 'All' || tags.includes(activeTag);
      const matchesSearch = title.includes(searchQuery.toLowerCase());

      if (matchesTag && matchesSearch) {
        (item as HTMLElement).style.display = '';
      } else {
        (item as HTMLElement).style.display = 'none';
      }
    });
  }

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      activeTag = btn.getAttribute('data-tag') ?? 'All';

      // Update active state
      buttons.forEach(b => {
        b.classList.remove(...activeClass);
        b.classList.add(...inactiveClass);
      });
      btn.classList.remove(...inactiveClass);
      btn.classList.add(...activeClass);

      filterPosts();
    });
  });

  searchInput?.addEventListener('input', (e) => {
    searchQuery = (e.target as HTMLInputElement).value;
    filterPosts();
  });
</script>
