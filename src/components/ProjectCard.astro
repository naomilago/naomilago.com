---
interface Props {
  title: string;
  description: string;
  tag: string;
  icon?:
    | 'yara'
    | 'kedward'
    | 'diver'
    | 'sentimetrix'
    | 'echogrowth'
    | 'goldenlens'
    | 'similarity';
}

const { title, description, tag, icon = 'yara' } = Astro.props;
---

<div
  class="group bg-white dark:bg-[#12102a] border border-[#e8e3f5] dark:border-[#22203a] rounded-xl p-4 hover:border-[#c4b0e8] dark:hover:border-[#3a2e60] transition-colors duration-150 cursor-pointer"
>
  <div class="flex justify-between items-start mb-4">
    <!-- Icon -->
    <div class="w-8 h-8 rounded-md flex items-center justify-center bg-[#ede9f8] dark:bg-[#1e1a40]">
      {icon === 'yara' && (
        <svg
          width="16"
          height="16"
          viewBox="0 0 16 16"
          fill="none"
          aria-hidden="true"
          class="transition-transform duration-200 group-hover:scale-110"
        >
          <path d="M8 2.5C5.5 2.5 3.5 4.4 3.5 6.8C3.5 9.9 6.7 12.6 8 13.5C9.3 12.6 12.5 9.9 12.5 6.8C12.5 4.4 10.5 2.5 8 2.5Z" fill="#7c5cbf" opacity="0.18" />
          <path d="M8 4.1C6.5 4.1 5.3 5.2 5.3 6.7C5.3 8.6 7.2 10.3 8 10.9C8.8 10.3 10.7 8.6 10.7 6.7C10.7 5.2 9.5 4.1 8 4.1Z" stroke="#7c5cbf" stroke-width="1.2" />
          <circle cx="8" cy="6.7" r="1.1" fill="#7c5cbf" />
        </svg>
      )}

      {icon === 'kedward' && (
        <svg
          width="16"
          height="16"
          viewBox="0 0 16 16"
          fill="none"
          aria-hidden="true"
          class="transition-transform duration-200 group-hover:scale-110"
        >
          <path d="M3 4.2C3 3.54 3.54 3 4.2 3H11.8C12.46 3 13 3.54 13 4.2V11.8C13 12.46 12.46 13 11.8 13H4.2C3.54 13 3 12.46 3 11.8V4.2Z" stroke="#7c5cbf" stroke-width="1.2" />
          <path d="M5 5.3H11" stroke="#7c5cbf" stroke-width="1.2" stroke-linecap="round" />
          <path d="M5 7.4H11" stroke="#7c5cbf" stroke-width="1.2" stroke-linecap="round" opacity="0.7" />
          <path d="M5 9.5H8.8" stroke="#7c5cbf" stroke-width="1.2" stroke-linecap="round" opacity="0.45" />
          <circle cx="11.2" cy="11.2" r="1.2" fill="#7c5cbf" opacity="0.2" />
        </svg>
      )}

      {icon === 'diver' && (
        <svg
          width="16"
          height="16"
          viewBox="0 0 16 16"
          fill="none"
          aria-hidden="true"
          class="transition-transform duration-200 group-hover:scale-110"
        >
          <path d="M3 4.5C3 3.67 3.67 3 4.5 3H11.5C12.33 3 13 3.67 13 4.5V9.2C13 10.03 12.33 10.7 11.5 10.7H7.1L4.6 12.8V10.7H4.5C3.67 10.7 3 10.03 3 9.2V4.5Z" stroke="#7c5cbf" stroke-width="1.2" />
          <circle cx="5.7" cy="6.8" r="0.7" fill="#7c5cbf" />
          <circle cx="8" cy="6.8" r="0.7" fill="#7c5cbf" opacity="0.7" />
          <circle cx="10.3" cy="6.8" r="0.7" fill="#7c5cbf" opacity="0.45" />
        </svg>
      )}

      {icon === 'sentimetrix' && (
        <svg
          width="16"
          height="16"
          viewBox="0 0 16 16"
          fill="none"
          aria-hidden="true"
          class="transition-transform duration-200 group-hover:scale-110"
        >
          <path d="M3.2 10.8L5.4 8.6L7.1 9.8L10 5.8L12.8 7.2" stroke="#7c5cbf" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
          <circle cx="3.2" cy="10.8" r="1" fill="#7c5cbf" opacity="0.35" />
          <circle cx="5.4" cy="8.6" r="1" fill="#7c5cbf" opacity="0.55" />
          <circle cx="7.1" cy="9.8" r="1" fill="#7c5cbf" opacity="0.75" />
          <circle cx="10" cy="5.8" r="1" fill="#7c5cbf" />
          <circle cx="12.8" cy="7.2" r="1" fill="#7c5cbf" opacity="0.5" />
        </svg>
      )}

      {icon === 'echogrowth' && (
        <svg
          width="16"
          height="16"
          viewBox="0 0 16 16"
          fill="none"
          aria-hidden="true"
          class="transition-transform duration-200 group-hover:scale-110"
        >
          <path d="M3 12.5H13" stroke="#7c5cbf" stroke-width="1.2" stroke-linecap="round" opacity="0.35" />
          <path d="M4.2 10.8L6.6 8.5L8.4 9.2L11.8 5.4" stroke="#7c5cbf" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M10.3 5.4H11.8V6.9" stroke="#7c5cbf" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
          <circle cx="4.2" cy="10.8" r="0.9" fill="#7c5cbf" opacity="0.45" />
          <circle cx="6.6" cy="8.5" r="0.9" fill="#7c5cbf" opacity="0.65" />
          <circle cx="8.4" cy="9.2" r="0.9" fill="#7c5cbf" opacity="0.8" />
          <circle cx="11.8" cy="5.4" r="0.9" fill="#7c5cbf" />
        </svg>
      )}

      {icon === 'goldenlens' && (
        <svg
          width="16"
          height="16"
          viewBox="0 0 16 16"
          fill="none"
          aria-hidden="true"
          class="transition-transform duration-200 group-hover:scale-110"
        >
          <circle cx="7" cy="7" r="3.2" stroke="#7c5cbf" stroke-width="1.2" />
          <circle cx="7" cy="7" r="1.2" fill="#7c5cbf" opacity="0.8" />
          <path d="M9.6 9.6L12.6 12.6" stroke="#7c5cbf" stroke-width="1.2" stroke-linecap="round" />
          <path d="M11.2 3.2L11.6 4.1L12.5 4.5L11.6 4.9L11.2 5.8L10.8 4.9L9.9 4.5L10.8 4.1L11.2 3.2Z" fill="#7c5cbf" opacity="0.45" />
        </svg>
      )}

      {icon === 'similarity' && (
        <svg
          width="16"
          height="16"
          viewBox="0 0 16 16"
          fill="none"
          aria-hidden="true"
          class="transition-transform duration-200 group-hover:scale-110"
        >
          <circle cx="5.2" cy="8" r="2.2" stroke="#7c5cbf" stroke-width="1.2" />
          <circle cx="10.8" cy="8" r="2.2" stroke="#7c5cbf" stroke-width="1.2" opacity="0.6" />
          <path d="M7.4 8C7.7 7.2 8.3 6.6 9 6.2" stroke="#7c5cbf" stroke-width="1.2" stroke-linecap="round" />
          <path d="M7.4 8C7.7 8.8 8.3 9.4 9 9.8" stroke="#7c5cbf" stroke-width="1.2" stroke-linecap="round" opacity="0.7" />
        </svg>
      )}
    </div>

    <!-- Tag -->
    <span class="text-[8px] font-medium tracking-[0.04em] bg-[#ede9f8] dark:bg-[#1e1a40] text-[#5c3fa3] dark:text-[#b89aec] px-2 py-0.5 rounded-sm">
      {tag}
    </span>
  </div>

  <p class="text-[13px] font-medium text-[#150a35] dark:text-[#d0caff] mb-1">{title}</p>
  <p class="text-[11px] text-[#777] dark:text-[#6868a0]">{description}</p>
</div>