---
interface Props {
  title: string;
  excerpt: string;
  date: string;
  readTime: string;
  tags: string[];
  slug: string;
  lang?: string;
}
const { title, excerpt, date, readTime, tags, slug, lang = 'en' } = Astro.props;
const href = lang === 'pt' ? `/pt/blog/${slug}` : `/blog/${slug}`;
---

<a href={href} class="block no-underline group">
  <div class="flex items-start justify-between gap-6 py-5 border-b border-[#e8e3f5] dark:border-[#1e1a38]">
    <!-- Left -->
    <div class="flex-1 min-w-0">
      <div class="flex gap-1.5 mb-2 flex-wrap">
        {tags.map(tag => (
          <span class="text-[9px] font-medium tracking-[0.06em] bg-[#f0ecfc] dark:bg-[#1a1838] text-[#5c3fa3] dark:text-[#a080e0] px-2 py-0.5 rounded-sm uppercase">
            {tag}
          </span>
        ))}
      </div>
      <p class="text-[14px] font-medium text-[#150a35] dark:text-[#e2dcff] mb-1 group-hover:text-[#7c5cbf] dark:group-hover:text-[#b89aec] transition-colors duration-150 leading-snug">
        {title}
      </p>
      <p class="text-[12px] text-[#777] dark:text-[#6868a0] leading-relaxed line-clamp-2">
        {excerpt}
      </p>
    </div>
    <!-- Right -->
    <div class="flex-shrink-0 text-right pt-0.5">
      <p class="text-[12px] text-[#999] dark:text-[#5a5888]">{date}</p>
      <p class="text-[11px] text-[#bbb] dark:text-[#4a4868] mt-0.5">{readTime}</p>
    </div>
  </div>
</a>
